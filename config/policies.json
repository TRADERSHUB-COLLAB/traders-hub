{
  "policies": [
    {
      "name": "api-key-auth",
      "policyType": "api-key-inbound",
      "handler": {
        "export": "ApiKeyInboundPolicy",
        "module": "$import(@zuplo/runtime)",
        "options": {
          "allowUnauthenticatedRequests": false
        }
      }
    },
    {
      "name": "tier-rate-limit",
      "policyType": "complex-rate-limit-inbound",
      "handler": {
        "export": "ComplexRateLimitInboundPolicy",
        "module": "$import(@zuplo/runtime)",
        "options": {
          "rateLimits": [
            {
              "rateLimitBy": "user",
              "requestsAllowed": 10000,
              "timeWindowMinutes": 1440,
              "matchingMetadata": { "tier": "pro" },
              "headers": { "headerMode": "standard" }
            },
            {
              "rateLimitBy": "user",
              "requestsAllowed": 100,
              "timeWindowMinutes": 1440,
              "headers": { "headerMode": "standard" }
            }
          ]
        }
      }
    },
    {
      "name": "anything-goes",
      "policyType": "cors-inbound",
      "handler": {
        "export": "CorsInboundPolicy",
        "module": "$import(@zuplo/runtime)",
        "options": {
          "allowOriginsAnything": true,
          "allowHeaders": ["Authorization", "Content-Type"],
          "allowMethods": ["GET", "OPTIONS"],
          "allowCredentials": false
        }
      }
    }
  ]
}

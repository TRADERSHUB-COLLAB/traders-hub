{
  "openapi": "3.1.0",
  "info": {
    "version": "1.0.0",
    "title": "Traders Hub — Intraday Trading Signal API",
    "description": "Get BUY / SELL / HOLD signals for any US stock ticker, based on RSI and moving-average crossover indicators. Built for intraday traders, algo developers, and dashboard builders.\n\n## Getting Started\n\nAll endpoints return JSON. Pass your API key via the `Authorization: Bearer <key>` header. Get a free key from the developer portal.\n\n## Pricing Tiers\n\n- **Free**: 100 calls / day\n- **Pro**: 10,000 calls / day (configure in the Zuplo dashboard)\n\n## Disclaimer\n\nFor informational purposes only. Not financial advice.",
    "contact": {
      "name": "Traders Hub Support",
      "email": "kobusmnel@gmail.com"
    }
  },
  "paths": {
    "/v1/signal": {
      "get": {
        "summary": "Get a trading signal",
        "description": "**Returns a BUY / SELL / HOLD recommendation** for a given US stock ticker, with a confidence score (0-100), last price, and the underlying indicator values (RSI, trend).\n\n### Example\n\n`GET /v1/signal?ticker=AAPL`\n\n```json\n{\n  \"ticker\": \"AAPL\",\n  \"signal\": \"BUY\",\n  \"confidence\": 70,\n  \"last_price\": 271.35,\n  \"indicators\": { \"rsi\": 61.64, \"rsi_status\": \"neutral\", \"trend\": \"uptrend\" }\n}\n```",
        "operationId": "get-signal",
        "parameters": [
          {
            "name": "ticker",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "minLength": 1, "maxLength": 8 },
            "description": "Stock ticker symbol, e.g. AAPL, TSLA, MSFT",
            "example": "AAPL"
          },
          {
            "name": "period",
            "in": "query",
            "required": false,
            "schema": { "type": "string", "enum": ["1mo", "3mo", "6mo", "1y"], "default": "3mo" },
            "description": "How much price history to analyse"
          }
        ],
        "responses": {
          "200": {
            "description": "Trading signal returned successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Signal" },
                "examples": {
                  "buy_aapl": {
                    "summary": "Bullish signal for AAPL",
                    "value": {
                      "ticker": "AAPL",
                      "signal": "BUY",
                      "confidence": 70,
                      "last_price": 271.35,
                      "indicators": { "rsi": 61.64, "rsi_status": "neutral", "trend": "uptrend" },
                      "as_of": "2026-04-30T20:22:34Z",
                      "disclaimer": "For informational purposes only. Not financial advice."
                    }
                  }
                }
              }
            }
          },
          "401": { "description": "Missing or invalid API key" },
          "404": { "description": "Ticker not found or insufficient price data" },
          "429": { "description": "Rate limit exceeded" },
          "502": { "description": "Upstream price-data error" }
        },
        "x-zuplo-route": {
          "corsPolicy": "anything-goes",
          "handler": {
            "export": "urlForwardHandler",
            "module": "$import(@zuplo/runtime)",
            "options": {
              "baseUrl": "https://traders-hub-signals.pplx.app/port/5000",
              "rewritePattern": "/signal"
            }
          },
          "policies": {
            "inbound": ["api-key-auth", "rate-limit-free-tier"]
          }
        },
        "tags": ["Signals"]
      }
    },
    "/v1/health": {
      "get": {
        "summary": "Health check",
        "description": "Verify the API and its upstream backend are alive. No API key required.",
        "operationId": "health",
        "responses": {
          "200": {
            "description": "API is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": { "status": { "type": "string", "example": "ok" } }
                }
              }
            }
          }
        },
        "x-zuplo-route": {
          "corsPolicy": "anything-goes",
          "handler": {
            "export": "urlForwardHandler",
            "module": "$import(@zuplo/runtime)",
            "options": {
              "baseUrl": "https://traders-hub-signals.pplx.app/port/5000",
              "rewritePattern": "/health"
            }
          }
        },
        "tags": ["System"]
      }
    }
  },
  "tags": [
    { "name": "Signals", "description": "Trading signal endpoints — BUY / SELL / HOLD recommendations." },
    { "name": "System", "description": "System endpoints — health checks, metadata." }
  ],
  "components": {
    "schemas": {
      "Signal": {
        "description": "A trading signal response with the recommendation, confidence, and underlying indicator values.",
        "type": "object",
        "properties": {
          "ticker": { "type": "string", "description": "The ticker symbol that was analysed", "example": "AAPL" },
          "signal": { "type": "string", "enum": ["BUY", "SELL", "HOLD"], "description": "The recommendation" },
          "confidence": { "type": "integer", "minimum": 0, "maximum": 100, "description": "Confidence score 0-100. Higher = stronger signal." },
          "last_price": { "type": "number", "description": "The last close price used in the calculation" },
          "indicators": {
            "type": "object",
            "properties": {
              "rsi": { "type": "number", "description": "Relative Strength Index value (0-100)" },
              "rsi_status": { "type": "string", "description": "Plain-English RSI interpretation" },
              "trend": { "type": "string", "enum": ["uptrend", "downtrend", "sideways"], "description": "10-day vs 30-day moving-average trend" }
            }
          },
          "as_of": { "type": "string", "format": "date-time", "description": "When the calculation was made (UTC)" },
          "disclaimer": { "type": "string" }
        },
        "required": ["ticker", "signal", "confidence", "last_price", "indicators"]
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Pass your API key as `Authorization: Bearer <your-key>`. Get one from the developer portal."
      }
    }
  },
  "security": [{ "ApiKeyAuth": [] }]
}
